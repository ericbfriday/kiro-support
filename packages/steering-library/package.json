{
  "name": "@kiro-transition/steering-library",
  "version": "0.0.1",
  "description": "Library of Kiro steering templates for common project types",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "node --test dist/**/*.test.js",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@kiro-transition/steering-generator": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "kiro",
    "steering",
    "templates",
    "ai"
  ],
  "license": "MIT"
}
