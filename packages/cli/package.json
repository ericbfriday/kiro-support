{
  "name": "@kiro-transition/cli",
  "version": "0.0.1",
  "description": "CLI for kiro-transition-toolkit - migrate projects to Kiro format",
  "type": "module",
  "bin": {
    "kiro-transition": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "node --test dist/**/*.test.js",
    "clean": "rm -rf dist *.tsbuildinfo",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "chalk": "^5.3.0",
    "ora": "^8.1.0",
    "@kiro-transition/env-scanner": "workspace:*",
    "@kiro-transition/steering-generator": "workspace:*",
    "@kiro-transition/context-migrator": "workspace:*",
    "@kiro-transition/hooks-library": "workspace:*",
    "@kiro-transition/skills-library": "workspace:*",
    "@kiro-transition/steering-library": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "kiro",
    "cli",
    "migration",
    "toolkit"
  ],
  "license": "MIT"
}
